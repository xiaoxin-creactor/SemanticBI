# LLM 配置（OpenAI 兼容接口）
LLM_API_KEY=your-api-key-here
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o

# HTTP 服务配置
SERVER_PORT=8080

# MCP 服务器配置（支持多个）
# STDIO 模式：通过命令行启动
MCP_SERVER__TIME__COMMAND=npx
MCP_SERVER__TIME__ARGS=-y,@modelcontextprotocol/server-time

# SSE 模式：通过 HTTP 连接
# MCP_SERVER__WEATHER__URL=http://localhost:8081/sse
